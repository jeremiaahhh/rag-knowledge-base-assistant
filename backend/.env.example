# --- App metadata -------------------------------------------------------------
APP_NAME="RAG Knowledge Base Assistant"
APP_VERSION=1.0.0
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- Database -----------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://rag:rag@localhost:5432/rag_knowledge_base

# --- Vector store -------------------------------------------------------------
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=rag_documents

# --- Uploads ------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25

# --- Chunking + retrieval -----------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4

# --- AI providers -------------------------------------------------------------
# Set USE_MOCK_AI=true to run the entire stack without external API keys.
USE_MOCK_AI=true

# OpenAI is used when USE_MOCK_AI=false AND a key is present.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
